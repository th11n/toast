{
  "name": "toast-monorepo",
  "private": true,
  "packageManager": "bun@1.3.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "@radix-ui/react-collapsible": "1.1.14",
    "@radix-ui/react-use-controllable-state": "1.2.3"
  },
  "scripts": {
    "dev": "bun --filter demo dev",
    "build": "bun --filter @dominikkrakowiak/toast build && bun --filter demo build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "bun --filter demo generate:docs && bun --filter @dominikkrakowiak/toast typecheck && bun --filter demo typecheck",
    "test": "bun --filter @dominikkrakowiak/toast test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4"
  }
}
